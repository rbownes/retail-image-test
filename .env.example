# Copy to .env and fill in.
#   cp .env.example .env

# REQUIRED — Claude powers the critique and placement agents.
ANTHROPIC_API_KEY=

# REQUIRED if you want gpt-image-1 (the default web provider).
# Leave blank if you'll only use the local SD provider.
OPENAI_API_KEY=

# OPTIONAL — host port mappings. Change if 3000/8000 are taken.
FRONTEND_PORT=3000
BACKEND_PORT=8000

# OPTIONAL — defaults are sensible.
MAX_COST_USD_PER_JOB=2.00
CORS_ALLOW_ORIGINS=http://localhost:3000

# Browser-facing backend URL — must be reachable from the user's laptop.
# Default works when running compose on the same machine you browse from.
NEXT_PUBLIC_BACKEND_URL=http://localhost:8000

# Product branding (shown in header + browser tab).
PRODUCT_NAME=CanvasKit
PRODUCT_TAGLINE=Brief to brand-ready creative in under a minute.
